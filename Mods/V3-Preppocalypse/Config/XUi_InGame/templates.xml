<configs>
	<append xpath="/templates">
		<!-- Make cells not look like crap and item icons fit properly -->
	<kh60_backpack_item_stack controller="ItemStack" on_scroll="false" allow_dropping="true" prefix_id="false" show_favorites="false">
		<rect controller="${controller}" style="kh60_itemStack, hover" collider_scale="1.0" on_scroll="${on_scroll}" allow_dropping="${allow_dropping}" prefix_id="${prefix_id}" show_favorites="${show_favorites}" tooltip="{tooltip}" enabled="{# !defined('userlockmode') or !userlockmode}" >
			<sprite depth="2" name="backgroundMain" sprite="menu_empty3px" pos="-3,3" color="[black]" type="sliced" fillcenter="false"
				width="63" height="63" />
			<sprite depth="3" name="background" sprite="menu_empty3px" color="{selectionbordercolor}" type="sliced" globalopacity="true" fillcenter="false"
				width="58" height="58" />
			<sprite depth="2" name="highlightOverlay" color="{backgroundcolor}" pos="0,0" type="sliced" globalopacity="true"
				width="57" height="57" />

			<texture depth="3" name="backgroundTexture" material="Materials/Transparent Colored" globalopacity="true"
				size="58,58" />
			<sprite depth="8" name="favoriteIcon" width="24" height="24" sprite="server_favorite" pos="2,-2" foregroundlayer="true" visible="{isfavorite}"/>
			<sprite depth="6" name="itemIcon" width="55" height="55" atlas="ItemIconAtlas" sprite="{itemicon}" pivot="center" foregroundlayer="true" color="{iconcolor}"
				pos="30,-25" />
			<sprite depth="8" name="lockTypeIcon" width="17" height="17" sprite="{locktypeicon}" pos="2,-2" foregroundlayer="true"/>
			<sprite depth="8" name="itemtypeicon" width="24" height="24" sprite="ui_game_symbol_{itemtypeicon}" pos="2,-2" foregroundlayer="true" visible="{hasitemtypeicon}" color="{itemtypeicontint}" />

			<sprite depth="3" name="durabilityBackground" sprite="menu_empty3px" color="[darkGrey]" type="sliced" foregroundlayer="true" visible="{hasdurability}"
				width="56" height="7" pos="1, -50" />
			<filledsprite depth="4" name="durability" sprite="menu_empty2px" color="{durabilitycolor}" fill="{durabilityfill}" type="filled" foregroundlayer="true" visible="{hasdurability}"
				width="56" height="7" pos="1, -50" />

			<sprite depth="5" name="disabledOverlay" color="[darkGrey_half_alpha]" pos="1,-1" type="sliced" visible="false"
				width="57" height="57" />

			<label depth="7" name="stackValue" height="17" text="{itemcount}" font_size="26" effect="outline" justify="{#hasdurability ? 'Center' : 'Right'}"
				pos="-2,-45" width="55" />
			<label depth="7" name="timer" height="21" font_size="24" justify="center" pivot="center" color="[beige]" effect="outline"
				pos="35,-38" width="55" />
			<sprite depth="9" name="cancel" sprite="ui_game_symbol_x" color="255,0,0,255" type="sliced" visible="{# ishovered and islocked}" foregroundlayer="true"
				width="55" height="55" />
			<sprite depth="13" name="assembleIcon" sprite="{stacklockicon}" color="{stacklockcolor}" visible="{isassemblelocked}" pos="14,-14" foregroundlayer="true"
				size="28,28" />

			<sprite depth="14" name="quickswapIcon" size="30,30" sprite="server_refresh" pos="40,-2" foregroundlayer="true" visible="{isQuickSwap}" />

			<button name="rectSlotLock" depth="15" style="press, hover" width="65" height="65" visible="{# defined('userlockmode') and userlockmode}" sprite="" hoverscale="1" use_selection_box="true">
				<sprite depth="16" name="slotLockIcon" width="24" height="24" sprite="{# !defined('userlockmode') ? '' : (userlockedslot ? 'ui_game_symbol_lock' : 'ui_game_symbol_unlock') }" pos="50, -14" style="icon32px" pivot="center" color="{# !defined('userlockmode') ? '255,255,255,1' : (userlockedslot ? '222,206,163' : '255,255,255') }" />
			</button>
			<sprite depth="15" name="iconSlotLock" width="13" height="13" sprite="ui_game_symbol_lock" pos="50, -7" style="icon32px" pivot="center" visible="{# defined('userlockmode') and !userlockmode and userlockedslot }" color="[lightGrey]" />
		</rect>
	</kh60_backpack_item_stack>
		
		<!-- Make cells not look like crap and item icons fit properly - KhaineGB -->
		<kh12_craft_queue_stack>		
			<rect controller="RecipeStack" width="57" height="57" collider_scale="1.1" always_update="true">
				<sprite depth="2" name="backgroundMain" sprite="menu_empty3px" pos="-3,3" width="63" height="63" color="[black]" type="sliced" fillcenter="false"/>	
				<sprite name="background" color="[mediumGrey]" type="sliced" style="press" on_hover="true"/>
				<sprite depth="1" name="itemIcon" width="53" height="53" atlas="ItemIconAtlas" sprite="" pos="28,-28" pivot="center" foregroundlayer="true"/>
				<sprite depth="4" name="lockIcon" width="16" height="16" sprite="ui_game_symbol_hammer" pos="2,-2" foregroundlayer="true"/>
				<label depth="4" name="count" pos="4,-42" width="53" height="16" text="Test" font_size="16" justify="right" effect="outline" />
				<label depth="4" name="timer" pos="34,-38" width="55" height="16" font_size="16" justify="center" pivot="center" color="[beige]" effect="outline" effect_distance="1,1" effect_color="0,0,0,255"/>
				<sprite depth="2" name="overlay" width="55" height="55" color="32,32,32,128" type="sliced"/>
				<sprite depth="3" name="cancel" sprite="ui_game_symbol_x" width="55" height="55" color="255,0,0,0" type="sliced" foregroundlayer="true"/>
			</rect>
		</kh12_craft_queue_stack>
	</append>
</configs>