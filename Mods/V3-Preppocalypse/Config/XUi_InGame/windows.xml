<remove xpath="/windows/window[@name='HUDLeftStatBars']" />
<append xpath="/windows">
	<window name="HUDLeftStatBars" anchor="BottomLeft">
		<rect name="hud" pos="9,156" rows="2" cols="1" width="168" side="right">
		<!-- <grid name="hud" pos="9,52" rows="3" cols="1" width="171" cell_width="168" cell_height="47" repeat_content="false" side="left" pivot="BottomLeft"> -->
			<rect width="171" height="46" controller="HUDStatBar" stat_type="Stealth" visible="{statvisible}">
				<sprite depth="1" name="border" color="0,50,0,150" height="46" type="sliced"/>
				<sprite depth="2" name="background" color="0,50,0,140" type="sliced"/>

				<sprite depth="3" name="background" color="0,50,0,128" type="filled" fillspritepad="true" fill="1"/>

				<sprite depth="4" name="BarContent" color="{stealthcolor}" type="filled" fillspritepad="true" fill="{statfill}"/>
				<sprite depth="5" name="Icon" atlas="{staticonatlas}" sprite="ui_game_symbol_stealth2" size="35,35" pos="26,-24" pivot="center" foregroundlayer="true"/>
				<label depth="6" name="TextContent" pos="44,-23" font_size="32" color="[white]" justify="center" pivot="left" text="{statcurrent}" width="125" height="35"/>

				<sprite depth="8" name="border" color="0,50,0,255" type="sliced" fillcenter="false"/>
				<filledsprite depth="8" name="background" color="0,50,0,255" width="171" fillcenter="false" type="filled" fill="1"/>
				<filledsprite depth="3" name="background" color="0,50,0,255" width="170" fillcenter="false" type="filled" fill="1"/>
				<texture depth="9" pos="86,-23" width="177" height="52" pivot="center" texture="@modfolder:Textures/HUDleftstatsborder03.png"/>
			</rect>

			<!-- Stamina -->
			<rect width="171" height="30" pos="0,-54" controller="HUDStatBar" stat_type="Stamina" visible="{statvisible}">
				<sprite depth="1" name="border" color="0,50,0,128" type="sliced"/>
				<sprite depth="2" name="background" color="0,50,0,160" type="sliced"/>

				<sprite depth="3" name="background" color="0,50,0,160" width="169" type="filled" fillspritepad="true" fill="{statmodifiedmax}"/>

				<sprite depth="5" name="BarContent" color="0,54,255,160" width="169" type="filled" fillspritepad="true" fill="{statfill}"/>
				<sprite depth="6" name="Icon" atlas="{staticonatlas}" sprite="ui_game_symbol_stamina" size="26,26" pos="16,-15" pivot="center" foregroundlayer="true"/>
				<label depth="7" name="TextContent" pos="44,-17" font_size="26" color="[white]" justify="center" pivot="left" text="{statcurrentwithmax}" width="125" height="26"/>

				<sprite depth="8" name="border" color="0,50,0,255" type="sliced" fillcenter="false"/>
				<filledsprite depth="8" name="background" color="0,50,0,255" width="171" fillcenter="false" type="filled" fill="{statmodifiedmax}"/>
				<filledsprite depth="3" name="background" color="0,50,0,255" width="170" fillcenter="false" type="filled" fill="{statmodifiedmax}"/>
				<texture depth="9" pos="86,-15" width="177" height="36" pivot="center" texture="@modfolder:Textures/HUDleftstatsborder01.png"/>

				<sprite depth="8" visible="{sprintactive}" name="sprint" atlas="{uiatlas}" sprite="server_z_always_run" size="48,48" pos="164,-16" pivot="left"/>
			</rect>

			<!-- Health -->
			<rect width="171" height="30" pos="0,-87" controller="HUDStatBar" stat_type="Health" visible="{statvisible}">
				<sprite depth="1" name="border" color="0,50,0,128" type="sliced"/>
				<sprite depth="2" name="background" color="0,50,0,160" type="sliced"/>

				<sprite depth="3" name="background" color="0,50,0,160" width="169" type="filled" fillspritepad="true" fill="{statmodifiedmax}"/>

				<sprite depth="5" name="BarContent" color="255,0,0,160" width="169" type="filled" fillspritepad="true" fill="{statfill}"/>
				<sprite depth="6" name="Icon" atlas="{staticonatlas}" sprite="ui_game_symbol_health_cross" size="26,26" pos="16,-15" pivot="center" foregroundlayer="true"/>
				<label depth="7" name="TextContent" pos="44,-17" font_size="26" color="[white]" justify="center" pivot="left" text="{statcurrentwithmax}" width="125" height="26"/>

				<sprite depth="8" name="border" color="0,50,0,255" type="sliced" fillcenter="false"/>
				<filledsprite depth="8" name="background" color="0,50,0,255" width="171" fillcenter="false" type="filled" fill="{statmodifiedmax}"/>
				<filledsprite depth="3" name="background" color="0,50,0,255" width="170" fillcenter="false" type="filled" fill="{statmodifiedmax}"/>
				<texture depth="9" pos="86,-15" width="177" height="36" pivot="center" texture="@modfolder:Textures/HUDleftstatsborder01.png"/>
			</rect>

			<!-- Food -->
			<rect width="83" height="30" pos="0,-120" controller="HUDStatBar" stat_type="Food" visible="{statvisible}">
