				<sprite depth="2" name="background" color="0,50,0,160" type="sliced"/>

				<sprite depth="3" name="background" color="0,50,0,160" width="83" type="filled" fillspritepad="true" fill="{statmodifiedmax}"/>

				<sprite depth="5" name="BarContent" color="0,255,54,160" width="82" type="filled" fillspritepad="true" fill="{statfill}"/>
				<sprite depth="6" name="Icon" atlas="{staticonatlas}" sprite="ui_game_symbol_food" size="26,26" pos="16,-15" pivot="center" foregroundlayer="true"/>
				<label depth="7" name="TextContent" pos="35,-15" font_size="20" color="[white]" justify="center" pivot="left" text="{statcurrent}%" width="45" height="26"/>

				<sprite depth="8" name="border" color="0,50,0,255" type="sliced" fillcenter="false"/>
				<filledsprite depth="8" name="background" color="0,50,0,255" width="83" fillcenter="false" type="filled" fill="{statmodifiedmax}"/>
				<filledsprite depth="3" name="background" color="0,50,0,255" width="84" fillcenter="false" type="filled" fill="{statmodifiedmax}"/>
				<texture depth="9" pos="86,-15" width="177" height="36" pivot="center" texture="@modfolder:Textures/HUDleftstatsborder02.png"/>
			</rect>

			<!-- Water -->
			<rect width="83" height="30" pos="87,-120" controller="HUDStatBar" stat_type="Water" visible="{statvisible}">
				<sprite depth="1" name="border" color="0,50,0,128" type="sliced"/>
				<sprite depth="2" name="background" color="0,50,0,160" type="sliced"/>

				<sprite depth="3" name="background" color="0,50,0,160" width="83" type="filled" fillspritepad="true" fill="{statmodifiedmax}"/>

				<sprite depth="5" name="BarContent" color="51,204,255,160" width="83" type="filled" fillspritepad="true" fill="{statfill}"/>
				<sprite depth="6" name="Icon" atlas="{staticonatlas}" sprite="ui_game_symbol_water_flask" size="26,26" pos="16,-15" pivot="center" foregroundlayer="true"/>
				<label depth="7" name="TextContent" pos="35,-15" font_size="20" color="[white]" justify="center" pivot="left" text="{statcurrent}%" width="45" height="26"/>

				<sprite depth="8" name="border" color="0,50,0,255" type="sliced" fillcenter="false"/>
				<filledsprite depth="8" name="background" color="0,50,0,255" width="83" fillcenter="false" type="filled" fill="{statmodifiedmax}"/>
				<filledsprite depth="3" name="background" color="0,50,0,255" width="84" fillcenter="false" type="filled" fill="{statmodifiedmax}"/>
			</rect>
		</rect>

		<rect name="hud" pos="90,132" side="left" controller="BuffPopoutList" pivot="BottomLeft" >
			<rect width="168" height="46" name="item" pivot="center" pos="70, 0" style="press" sound="[recipe_click]" on_hover="true" >
				<sprite depth="3" pos="0,0"  name="Background" sprite="ui_game_popup" height="46" width="162" pivot="center" flip="Horizontally" color="[transparent]" />
				<filledsprite depth="4" pos="-80,0" name="BarContent" color="0,0,0,0" size="160,40" pivot="Left" type="filled"/>
				<sprite depth="5" name="Icon" size="40,40" pos="-54,0" pivot="center" color="[transparent]"/>
				<label depth="6" name="TextContent" pos="-37,0" font_size="28" color="[white]" justify="center" size="118,40" pivot="left"/>
			</rect>
		</rect>
	</window>
</append>
	
</Preppocalypse>
