<Preppocalypse>

	<!-- KhaineGB's 60 Slot Inventory - Much thanks -->
    <!-- update the overall backpack size -->
    <set xpath="/windows/window[@name='windowBackpack']/@width">604</set>
    <set xpath="/windows/window[@name='windowBackpack']/@height">373</set>
    
    <!-- increase the rect size -->
    <set xpath="/windows/window[@name='windowBackpack']/rect[@name='content']/@height">330</set>
    
    <!-- adjust the rows, heights, and their cell equivalent -->
    <set xpath="/windows/window[@name='windowBackpack']/rect[@name='content']/grid[@name='inventory']/@rows">6</set>
    <set xpath="/windows/window[@name='windowBackpack']/rect[@name='content']/grid[@name='inventory']/@cols">10</set>
    <set xpath="/windows/window[@name='windowBackpack']/rect[@name='content']/grid[@name='inventory']/@cell_height">60</set>
    <set xpath="/windows/window[@name='windowBackpack']/rect[@name='content']/grid[@name='inventory']/@cell_width">60</set>
    <set xpath="/windows/window[@name='windowBackpack']/rect[@name='content']/sprite[@name='backgroundMain']/@width">601</set>
    <set xpath="/windows/window[@name='windowBackpack']/rect[@name='content']/sprite[@name='backgroundMain']/@height">363</set>
	
	<!-- adjust windowlooting to match the size of the new player dropped backpack container -->
    <set xpath="/windows/window[@name='windowLooting']/rect[@name='content']/grid[@name='queue']/@rows">10</set>
    <set xpath="/windows/window[@name='windowLooting']/rect[@name='content']/grid[@name='queue']/@cols">10</set>
	
	<remove xpath="/windows/window[@name='windowBackpack']/rect[@name='content']/grid[@name='inventory']/item_stack"></remove>
	
	<append xpath="/windows/window[@name='windowBackpack']/rect[@name='content']/grid[@name='inventory']">
       <kh60_backpack_item_stack name="0"/>
	</append>
	
	<!-- KhaineGB's 12 Slot Crafting Queue - Much thanks -->	
    <!-- update the overall backpack size -->
	
    <set xpath="/windows/window[@name='windowCraftingQueue']">
		<rect depth="0" pos="-52,-90" width="303" controller="CraftingQueue" always_update="true">
			<grid name="queue" rows="2" cols="6" pos="73,82" cell_width="60" cell_height="60" repeat_content="true" always_update="true">
				<kh12_craft_queue_stack name="0"/>
			</grid>
		</rect>
	</set>

	<!-- KhaineGB's 3 Slot Forge Mod - Much thanks -->
	<append xpath="/windows">
		<window name="windowThreeForgeInput" width="228" height="229" panel="Right"
			controller="WorkstationMaterialInputWindow" materials_accepted="iron,brass,lead,glass,stone,clay" valid_materials_color="[green]" invalid_materials_color="[red]" cursor_area="true" >
			<rect style="header.panel" pos="0,2">
				<headerbg />
				<sprite style="header.icon" sprite="ui_game_symbol_forge"/>
				<label style="header.name.shrink" text="INPUT" text_key="xuiSmelting" />
			</rect>

			<sprite depth="2" name="backgroundMain" sprite="menu_empty3px" pos="0,-43" height="228" color="[black]" type="sliced" fillcenter="false" />
			<rect name="content" depth="1" pos="0,-121" height="153">

				<grid depth="7" rows="3" cols="1" pos="3,75" cell_width="75" cell_height="75" controller="WorkstationMaterialInputGrid" repeat_content="true">
					<item_stack name="0"/>
				</grid>

			</rect>

			<rect name="content2" depth="0" pos="78, -46" width="147" height="223">
				<sprite depth="1" color="[mediumGrey]" type="sliced"/>
				<grid rows="7" cols="1" pos="3,-3" cell_width="147" cell_height="32"  repeat_content="true">
					<forge_material name="0"/>
				</grid>
			</rect>
		</window>

		<window name="windowThreeForgeOutput" pos="0,-48" width="228" height="152" anchor="Top" panel="Right" cursor_area="true" controller="WorkstationOutputWindow" >
			<rect style="header.panel" pos="0,-38">
				<headerbg />
				<sprite style="header.icon" sprite="ui_game_symbol_loot_sack"/>
				<label style="header.name.iconright" text="OUTPUT" text_key="xuiOutput"/>
				
				<rect pos="0,0" controller="ContainerStandardControls" visible="{buttons_visible}">
					<button   depth="3" name="btnMoveAll"          sprite="ui_game_symbol_store_all_up"     tooltip="{take_all_tooltip}"          pos="203, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
				</rect>
			</rect>

			<rect name="content" depth="0" pos="0,-83" height="150" disablefallthrough="true">
				<sprite depth="2" name="backgroundMain" sprite="menu_empty3px" height="150" color="[black]" type="sliced" fillcenter="false" />
					<grid depth="10" name="inventory" rows="2" cols="3" pos="3,-3" cell_width="75" cell_height="75" controller="WorkstationOutputGrid" repeat_content="true">
						<item_stack name="0"/>
					</grid>
			</rect>
		</window>		
	</append>
	
<!-- Preppocalypse UI -->
<remove xpath="/windows/window[@name='windowCompass']" />
<append xpath="/windows">		
	<window name="windowCompass" anchor="CenterTop" pos="-237,-16" width="480" height="43" controller="CompassWindow">
		<sprite depth="0" sprite="ui_game_header_fill" pos="47,0" width="386" height="43" type="sliced" color="0,50,0,150" />
		<sprite depth="1" sprite="ui_game_header_fill" pos="50,-3" width="380" height="37" type="sliced" color="0,50,0,220" />
		
		<texture depth="8" texture="@:Textures/UI/Compass/overlay-{compass_language}.png" pos="50, -12" width="380" height="27" color="[iconColor]" name="compassTexture3" rect_size="0.25,1" rect_offset="{#compass_rotation / 360 + 0.0625 - 0.125},0" />
		<texture depth="10" pos="239,0" width="35" height="35" pivot="center" texture="@modfolder:Textures/compass_pointer.png"/>
		<texture pos="242,-21" depth="8" width="500" height="47" pivot="center" texture="@modfolder:Textures/border2.png"/>
		
		<sprite pos="239,-60" sprite="" color="255,255,255,255" globalopacitymod="1.8" visible="{showtime}">
			<label depth="2" width="300" height="30" text="{daytitle}: [{daycolor}]{day}[-]     {timetitle}: {time}     [{outsidetempcolor}]{outsidetemp}[-]" font_size="28" pivot="center" effect="outline" upper_case="true" justify="center"/>
		</sprite>
		<!-- Elevation -->		
		<rect name="elevation" depth="12" pos="-24,26" width="100" height="50" controller="MapStats" visible="{statvisible}">
			<sprite depth="2" name="elevIcon" width="14" height="14" pos="25,-40" sprite="ui_game_symbol_climb" color="[iconColor]" foregroundlayer="true"/>
			<label depth="2" name="elevLabel" pos="40,-40" width="80" height="18" text="{mapelevation}" font_size="18" color="[white]" justify="left"/>
		</rect>		
	</window>		
</append>
	
<remove xpath="/windows/window[@name='interactionPrompt']" />
<append xpath="/windows">
	<window name="interactionPrompt" anchor="Center" pos="0,55" width="2000" height="70" controller="InteractionPrompt" fade_delay="0.02">
		<label name="lblText" font_size="34" effect="outline" effect_distance="1,1" effect_color="0,0,0,150" justify="center" pivot="center" text="{text}" parse_actions="true" actions_default_format="([EEEE22] ### [-])" />
	</window>
</append>
	
