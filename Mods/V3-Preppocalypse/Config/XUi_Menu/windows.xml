<Preppocalypse>

	<remove xpath="/windows/window[@name='menuBackground']" />
	<append xpath="/windows">
	<window name="menuBackground" anchor="Center" pos="0,0" width="1050" height="780" depth="-5">
		<sprite depth="0" color="[black]" globalopacitymod="0" anchor_left="#cam,0,-5" anchor_bottom="#cam,0,-5" anchor_right="#cam,1,5" anchor_top="#cam,1,5" />
		<texture depth="1" color="[white]" texture="@modfolder:Textures/background.png" name="bgTexture" anchor_left="#cam,0,-5" anchor_bottom="#cam,0,-5" anchor_right="#cam,1,5" anchor_top="#cam,1,5" />
	</window>
	</append>
	<remove xpath="/windows/window[@name='mainMenuNews']" />

  <!-- V3 Max Chunk Age default values: -1, 10, 20, 30, 40, 50, 75, 100 -->
  <set xpath="/windows/window[@name='newContinueGameSettings']/rect[@name='tabs']/rect[@name='tabsContents']/rect[@tab_key='xuiGameSettingsAdvanced']/scrollview/grid/gameoption[@name='MaxChunkAge']/@values">-1, 1, 2, 3, 4, 5, 6, 7, 10, 20, 30, 40, 50, 75, 100</set>
  <set xpath="/windows/window[@name='serverBrowser']/panel[@name='serverfilters']/rect[@name='tabs']/rect[@name='tabsContents']/rect[@tab_key='xuiGameSettingsAdvanced']/scrollview/grid/browsergameoptioncombined[@name='MaxChunkAge']/@values">-1, 1, 2, 3, 4, 5, 6, 7, 10, 20, 30, 40, 50, 75, 100</set>

  <!-- V3 Land Claim Size default values: 21, 31, 41, 51, 71 -->
  <set xpath="/windows/window[@name='newContinueGameSettings']/rect[@name='tabs']/rect[@name='tabsContents']/rect[@tab_key='xuiGameSettingsMultiplayer']/scrollview/grid/gameoption[@name='LandClaimSize']/@values">21, 31, 41, 51, 71, 101, 151</set>
  <set xpath="/windows/window[@name='serverBrowser']/panel[@name='serverfilters']/rect[@name='tabs']/rect[@name='tabsContents']/rect[@tab_key='xuiGameSettingsMultiplayer']/scrollview/grid/browsergameoptioncombined[@name='LandClaimSize']/@values">21, 31, 41, 51, 71, 101, 151</set>

  <!-- V3 Max Party Share Kill Range default values: 0, 100, 500, 1000, 5000, 10000 -->
  <set xpath="/windows/window[@name='newContinueGameSettings']/rect[@name='tabs']/rect[@name='tabsContents']/rect[@tab_key='xuiGameSettingsMultiplayer']/scrollview/grid/gameoption[@name='PartySharedKillRange']/@values">0, 10, 25, 50, 75, 100, 500, 1000, 5000, 10000, 16000</set>
  <set xpath="/windows/window[@name='serverBrowser']/panel[@name='serverfilters']/rect[@name='tabs']/rect[@name='tabsContents']/rect[@tab_key='xuiGameSettingsMultiplayer']/scrollview/grid/browsergameoptioncombined[@name='PartySharedKillRange']/@values">0, 10, 25, 50, 75, 100, 500, 1000, 5000, 10000, 16000</set>
	
</Preppocalypse>